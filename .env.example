# ========================================
# AI Provider Configuration
# ========================================

# Your Google Gemini API key (from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Your NVIDIA API key for Llama Vision (from https://build.nvidia.com/)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Which AI provider to use. Valid options: "gemini" or "nvidia"
AI_PROVIDER=nvidia

# ========================================
# File Upload Configuration
# ========================================

# Directory where uploaded documents are stored locally
UPLOAD_DIR=uploads

# Maximum allowed file size for uploads (in Megabytes)
MAX_FILE_SIZE_MB=10
